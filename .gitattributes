# Normalize line endings to LF on checkout for all platforms.
# Matches the .editorconfig `end_of_line = lf` rule so `dotnet format
# --verify-no-changes` passes on Windows CI runners (which default to
# core.autocrlf=true and would otherwise check out CRLF).
* text=auto eol=lf

# Binary files: never normalize.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.exe binary
*.dll binary
