<Window x:Class="DupeHunter.Gui.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DupeHunter.Gui.Views"
        xmlns:vm="clr-namespace:DupeHunter.Gui.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DupeHunter — duplicate review"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Toolbar -->
        <Grid DockPanel.Dock="Top" Margin="10,8" IsEnabled="{Binding IsNotBusy}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Report:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBox Grid.Column="1" Text="{Binding ReportPath, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"
                     ToolTip="Path to the duplicates .yml report written by the dupehunter CLI. Deleting copies here updates this file; the scan database is never touched." />
            <Button Grid.Column="2" Content="Open…" Margin="6,0,0,0" Padding="10,2"
                    Command="{Binding OpenReportCommand}" />
            <Button Grid.Column="3" Content="Refresh" Margin="6,0,16,0" Padding="10,2"
                    Command="{Binding RefreshCommand}" />
            <TextBlock Grid.Column="4" Text="Min wasted (MB):" VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBox Grid.Column="5" Text="{Binding MinWastedMb}" Width="60" VerticalContentAlignment="Center" Margin="0,0,16,0"
                     ToolTip="Hide sets wasting less than this. A view filter only — the report file keeps every set. Takes effect on Refresh." />
            <TextBox Grid.Column="6" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="200" VerticalContentAlignment="Center"
                     ToolTip="Filter groups by name" />
        </Grid>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <ProgressBar Width="90" Height="12" Margin="0,0,8,0" IsIndeterminate="True"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding StatusText}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem Content="{Binding ScanSummary}" />
            <Separator />
            <StatusBarItem Content="{Binding TotalWastedText}" />
        </StatusBar>

        <!-- Group lists -->
        <TabControl Margin="10,0,10,6">
            <TabItem Header="Duplicate folders">
                <views:GroupsView Groups="{Binding FolderGroupsView}" />
            </TabItem>
            <TabItem Header="Duplicate files">
                <views:GroupsView Groups="{Binding FileGroupsView}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
